# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values before running
# ─────────────────────────────────────────────────────────────────────────────

# ─── Client ───────────────────────────────────────────────────────────────────
# Picovoice Porcupine access key (https://console.picovoice.ai/)
PORCUPINE_ACCESS_KEY=your_picovoice_access_key

# Path to the compiled .ppn wake-word model file for "Hey AI"
PORCUPINE_KEYWORD_PATH=./wakeword/hey_ai.ppn

# WebSocket URI of the FastAPI server
SERVER_URI=ws://your-server-host:8000/ws/chat

# ─── Server ───────────────────────────────────────────────────────────────────
# FastAPI server bind address and port
HOST=0.0.0.0
PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Redis connection URL
REDIS_URL=redis://localhost:6379

# ─── LLM — provider selection ─────────────────────────────────────────────────
# Choose one: gemini | openai | openrouter | grok | together | deepseek | huggingface  (default: gemini)
LLM_PROVIDER=gemini

# ─── LLM — Gemini ─────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# Models: gemini-2.0-flash | gemini-1.5-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-1.5-flash

# ─── LLM — OpenAI ─────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
# Models: gpt-4o | gpt-4o-mini | gpt-4-turbo | o1-mini
OPENAI_MODEL=gpt-4o-mini

# ─── LLM — OpenRouter ─────────────────────────────────────────────────────────
# https://openrouter.ai/keys  (gateway to 200+ models)
OPENROUTER_API_KEY=your_openrouter_api_key
# Models: anthropic/claude-3.5-sonnet | google/gemini-2.0-flash | meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ─── LLM — Grok (xAI) ────────────────────────────────────────────────────────
# https://console.x.ai/
XAI_API_KEY=your_xai_api_key
# Models: grok-3 | grok-3-mini | grok-3-fast
GROK_MODEL=grok-3-mini

# ─── LLM — Together AI ────────────────────────────────────────────────────────
# https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=your_together_api_key
# Models: meta-llama/Llama-3.3-70B-Instruct-Turbo | mistralai/Mixtral-8x7B-Instruct-v0.1 | deepseek-ai/DeepSeek-R1
TOGETHER_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct-Turbo

# ─── LLM — DeepSeek ───────────────────────────────────────────────────────────
# https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=your_deepseek_api_key
# Models: deepseek-chat | deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ─── LLM — Hugging Face ───────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token
# Models: meta-llama/Llama-3.1-8B-Instruct | mistralai/Mistral-7B-Instruct-v0.3 | Qwen/Qwen2.5-7B-Instruct
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ─── TTS (Edge-TTS) ───────────────────────────────────────────────────────────
# Edge-TTS voice for Vietnamese (default: vi-VN-HoaiMyNeural)
TTS_VOICE=vi-VN-HoaiMyNeural

# ─── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
